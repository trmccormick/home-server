# ============================================================
# Raspberry Pi 4 Home Server – Environment Variables Reference
# ============================================================
# Per-service env files now live in env/<service>.env.
# Run the setup script to generate them from the bundled examples:
#   sudo ./scripts/setup.sh
#
# Then edit each file directly, e.g.:
#   nano env/common.env
#   nano env/duckdns.env
#   nano env/pihole.env
# ============================================================

# ------------------------------------------------------------
# env/common.env  –  shared by all containers
# ------------------------------------------------------------
# TZ=America/New_York
# PUID=1000
# PGID=1000

# ------------------------------------------------------------
# env/duckdns.env  –  Dynamic DNS updater
# ------------------------------------------------------------
# SUBDOMAINS=myhome
# TOKEN=your-duckdns-token-here
# LOG_FILE=false

# ------------------------------------------------------------
# env/samba.env  –  Samba file shares
# ------------------------------------------------------------
# USERID=1000
# GROUPID=1000
# SAMBA_PASSWORD=changeme

# ------------------------------------------------------------
# env/pihole.env  –  Network-wide ad blocking
# ------------------------------------------------------------
# WEBPASSWORD=changeme
# PIHOLE_DNS_=8.8.8.8;8.8.4.4
# FTLCONF_LOCAL_IPV4=192.168.1.100

# ------------------------------------------------------------
# env/postgres.env  –  PostgreSQL database
# ------------------------------------------------------------
# POSTGRES_USER=admin
# POSTGRES_PASSWORD=changeme
# POSTGRES_DB=homeserver

# ------------------------------------------------------------
# env/open-webui.env  –  Open WebUI (Ollama frontend)
# ------------------------------------------------------------
# OLLAMA_BASE_URL=http://192.168.1.200:11434
# DATABASE_URL=postgresql://admin:changeme@postgres:5432/homeserver
# WEBUI_SECRET_KEY=change-this-to-a-random-secret

# ------------------------------------------------------------
# env/portainer.env  –  Docker management UI
# (No required variables – configured via web UI on first launch)
# ------------------------------------------------------------
