# ============================================================
# Raspberry Pi 4 Home Server - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# General
# ------------------------------------------------------------
# Your local timezone (used by most containers)
TZ=America/New_York

# UID/GID of the user running the containers (run: id)
PUID=1000
PGID=1000

# Base path where all persistent data is stored
DATA_DIR=/mnt/data

# ------------------------------------------------------------
# DuckDNS
# ------------------------------------------------------------
# Your DuckDNS subdomain(s), comma-separated (no .duckdns.org suffix)
DUCKDNS_SUBDOMAINS=myhome

# Token from https://www.duckdns.org
DUCKDNS_TOKEN=your-duckdns-token-here

# ------------------------------------------------------------
# Jellyfin
# ------------------------------------------------------------
# Directories for media libraries
JELLYFIN_MEDIA_DIR=/mnt/data/media

# ------------------------------------------------------------
# Samba
# ------------------------------------------------------------
# Samba share password (for the smb user)
SAMBA_PASSWORD=changeme

# ------------------------------------------------------------
# Pi-hole
# ------------------------------------------------------------
# Web admin password for Pi-hole dashboard
PIHOLE_WEB_PASSWORD=changeme

# Upstream DNS server used by Pi-hole
PIHOLE_DNS=8.8.8.8;8.8.4.4

# Static IP of the Pi on your local network (used as Pi-hole's DNS)
SERVER_IP=192.168.1.100

# ------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=homeserver

# ------------------------------------------------------------
# Open WebUI (Ollama frontend)
# ------------------------------------------------------------
# URL of the Ollama server running on your local network
OLLAMA_BASE_URL=http://192.168.1.200:11434

# Secret key for Open WebUI session cookies (generate with: openssl rand -hex 32)
WEBUI_SECRET_KEY=change-this-to-a-random-secret
