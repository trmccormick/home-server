# ============================================================
# Open WebUI – Browser-based Ollama frontend
# ============================================================
# Copy to env/open-webui.env and fill in your values:
#   cp env/open-webui.env.example env/open-webui.env
# point the intel macbook to use http://<pi-ip>:3000/ollama in github copilot

# URLs of the Ollama server running on your local network
OLLAMA_BASE_URLS=http://192.168.x.x:11434;http://192.168.x.y:11434

# PostgreSQL connection string – update user/password/db to match env/postgres.env
DATABASE_URL=postgresql://admin:changeme@postgres:5432/homeserver

# Secret key for session cookies (generate with: openssl rand -hex 32)
WEBUI_SECRET_KEY=change-this-to-a-random-secret
