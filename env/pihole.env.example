# ============================================================
# Pi-hole – Network-wide ad blocking / local DNS
# ============================================================
# Copy to env/pihole.env and fill in your values:
#   cp env/pihole.env.example env/pihole.env

# Web admin password for the Pi-hole dashboard
WEBPASSWORD=changeme

# Upstream DNS servers (semicolon-separated)
PIHOLE_DNS_=8.8.8.8;8.8.4.4

# Static LAN IP of this server (used as the Pi-hole's local IPv4 address)
FTLCONF_LOCAL_IPV4=192.168.1.100
