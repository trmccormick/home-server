# ============================================================
# DuckDNS – Dynamic DNS updater
# ============================================================
# Copy to env/duckdns.env and fill in your values:
#   cp env/duckdns.env.example env/duckdns.env

# Your DuckDNS subdomain(s), comma-separated (no .duckdns.org suffix)
SUBDOMAINS=myhome

# Token from https://www.duckdns.org
TOKEN=your-duckdns-token-here

# Write updates to a log file inside the container (true/false)
LOG_FILE=false
