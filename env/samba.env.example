# ============================================================
# Samba – Network file shares
# ============================================================
# Copy to env/samba.env and fill in your values:
#   cp env/samba.env.example env/samba.env

# UID/GID for the samba user (should match PUID/PGID in common.env)
USERID=1000
GROUPID=1000

# Password for the smbuser Samba account
SAMBA_PASSWORD=changeme
